# Auto detect text files
* text=auto

# Python
*.py text eol=lf
*.pyx text eol=lf

# Notebooks
*.ipynb text eol=lf

# Web
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.pdf binary
